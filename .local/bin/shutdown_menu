#!/bin/bash

ANSWER=$(echo -e "Bildschirm aufnehmen\nBildschirm Sperren\nAbmelden\nHerunterfahren\nNeu Starten\nAbbrechen" | rofi -dmenu -i -p "Startmenu")
case $ANSWER in
    "Bildschirm aufnehmen") screen ;;
    "Bildschirm Sperren")   slock ;;
    "Abmelden")         bspc quit && pkill -KILL -u $(whoami);;
    "Herunterfahren")   shutdown now ;;
    "Neu Starten")      shutdown -r now;;
    "Abbruch")          echo "mission abort";;
esac
