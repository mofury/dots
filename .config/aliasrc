# ls macros
alias ls="exa --icons"
alias la="exa -a --icons"
alias ll="exa -la --icons"
alias ld="exa -TD --icons"
alias tree="exa -T --icons"

# vimlike shortcut to clear
alias zt="clear"

# color
alias grep="grep --color=auto"
alias ip="ip -color=auto"
alias make="colormake"
alias ping="prettyping"

# being polite
alias please="sudo"

# git alias for dotfiles repo
alias dots="git --git-dir=$HOME/.dots.git/ --work-tree=$HOME"

# vim alias
alias v="vim"

# config files
alias zrc="vim ~/.config/zsh/.zshrc && source ~/.config/zsh/.zshrc"
alias alrc="vim ~/.config/aliasrc && source ~/.config/aliasrc"
alias bsrc="vim ~/.config/bspwm/bspwmrc"
alias sxrc="vim ~/.config/sxhkd/sxhkdrc"
alias porc="vim ~/.config/polybar/config.ini"
alias vrc="vim ~/.config/vim/vimrc"
alias nvrc="nvim ~/.config/nvim/init.vim"
