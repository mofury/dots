#      ---
# Manage windows
#      ---

# close the current node
super + Delete
    bspc node -c

# focus the older or newer node in the focus history
super + {j,k}
    bspc node -f {next,prev}.local

# resize the master/stack
super + {h,l}
	bspc node -z {left -40 0,left 40 0}

# swap the current and the biggest or the next node
super + Return
    bspc node -s biggest.local || bspc node -s next.local

# focus or send to the given desktop
super + {_,shift + }{1-9,0}
	bspc {desktop -f,node -d} '^{1-9,10}'

# focus the next/previous desktop in the current monitor
super + shift + {j,k}
	bspc desktop -f {next,prev}.local

# focus the next/previous monitor
super + shift + {h,l}
    bspc monitor -f {prev,next}

# focus the last used desktop/monitor
super + {_,shift + }Tab
    bspc {desktop,monitor} -f last

# set the state of the current node
super + {t,g}
    bspc node -t {tiled,floating}

# activate monocle mode and increase padding
super + {i,o}
    fs_helper {monocle 700, tiled 0}

# activate monocle mode with dynamic padding
super + shift + {i,o}
    fs_helper {monocle,tiled} $(rofi -dmenu -p "Rand in px")

# move a floating window
super + ctrl + {h,j,k,l}
    bspc node -v {-20 0,0 20,0 -20,20 0}

#     ---
# Configuration
#     ---

# reload various configuration files
super + r
    reload_helper

# reload sxhkd configuration
super + shift + r
    prompt "sxhkd neu laden?" "pkill -USR1 -x sxhkd"

# toggle bar
super + b
    (pkill polybar && bspc config bottom_padding 0) || \
    polybar small

#    ---
# Media keys
#    ---

# mute audio
XF86AudioMute
    amixer sset IEC958 toggle

# next/previos track
XF86Audio{Next,Prev}
    playerctl {next,previous}

# play/pause
XF86Audio{Pause,Play}
    playerctl play-pause

# stop
XF86AudioStop
    song_change

#   ---
# Bindings
#   ---

# show help
super + q
    helper

# power menu
super + Escape
    power_menu

# lock the screen
super + shift + Escape
    prompt "Den Bildschirm sperren?" "slock"

# application launcher
super + space
    rofi -show run

# window switcher
super + shift + space
    rofi -show window

# terminal
super + BackSpace
    $TERMINAL

# scratchpad terminal
super + f
    scratchpad dropdown

# spotify controler
super + s
    scratchpad spotify

# websearch
super + d
    websearch

# change wallpaper
super + w
    wallpaper

# browser
super + e
    $BROWSER

# alternative browser
super + shift + e
    $BROWSER_ALT

# inkscape
super + a
    inkscape

# zathura
super + y
    zathura
