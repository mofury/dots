# Open windows

# open scratchpad
super + g
    scratchpad dropdown

# open spotify control
super + shift + s
    scratchpad spotify ; [ -z "$(ps -A | grep spotifyd)" ] && spotifyd

# open Terminal
super + m
	$TERMINAL

# application launcher
super + d
	rofi -show run

# window switcher
super + w
    rofi -show window

# open browser
super + u
    $BROWSER

# open alt browser
super + shift + u
    $BROWSER_ALT

# change wallpaper
super + shift + w
    wallpaper

# show keybinding help
super + shift + g
    helper


# Media keys
# mute audio
XF86AudioMute
    amixer sset IEC958 toggle

# next/previos track
XF86Audio{Next,Prev}
    playerctl {next,previous}

# play/pause
XF86Audio{Pause,Play}
    playerctl play-pause


# Reload configs
# make sxhkd reload its configuration files:
super + e
	pkill -USR1 -x sxhkd

# reload bspwm config
super + shift + r
    $HOME/.config/bspwm/bspwmrc

# hide / show small polybar
super + a
    pkill polybar && polybar small

# hide/show full polybar
super + r
    pkill polybar && polybar full


# Quit things
# quit bspwm
super + alt + q
	prompt "BSPWM schliessen?" "bspc quit"

# lock screen
super + shift + d
    slock

# shutdown menu
super + shift + x
    shutdown_menu


# Manage windows
# close or kill
super + {_,shift + }q
	bspc node -{c,k}

# swap the current node and the biggest local node
super + Return
	bspc node -s biggest.local || bspc node -s next.local

# set the window state
super + {t,shift + t,s}
	bspc node -t {tiled,pseudo_tiled,floating}

# alternate between tiles and monocle layout
super + {_,shift + } f
    bspc {desktop -l next,node - ~fullscreen}


# Focus/Swap
# focus the node in the given direction
super + {_,shift + }{h,j,k,l}
	bspc node -{f,s} {west,south,north,east}

# focus the next/previous node in the current desktop
super + {_,shift + }c
	bspc node -f {next,prev}.local

# focus or send to the given desktop
super + {_,shift + }{1-9,0}
	bspc {desktop -f,node -d} '^{1-9,10}'

# focus the next/previous desktop in the current monitor
super + bracket{left,right}
	bspc desktop -f {prev,next}.local

# focus the older or newer node in the focus history
super + {o,i}
	bspc wm -h off; \
	bspc node {older,newer} -f; \
	bspc wm -h on

# Preselect
# preselect the direction
super + alt + {h,j,k,l}
	bspc node -p {west,south,north,east}

# cancel the preselection for the focused node
super + alt + space
	bspc node -p cancel

# cancel the preselection for the focused desktop
super + alt + shift + space
	bspc query -N -d | xargs -I id -n 1 bspc node id -p cancel

# Move/Resize
# expand a window by moving one of its side outward
super + ctrl + {h,j,k,l}
	bspc node -z {left -20 0,bottom 0 20,top 0 -20,right 20 0}

# contract a window by moving one of its side inward
super + ctrl + shift + {h,j,k,l}
	bspc node -z {right -20 0,top 0 20,bottom 0 -20,left 20 0}

# move a floating window
super + {Left,Down,Up,Right}
	bspc node -v {-20 0,0 20,0 -20,20 0}
